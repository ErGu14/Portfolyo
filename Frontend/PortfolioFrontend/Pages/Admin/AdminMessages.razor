@page "/admin/messages"
@layout AdminLayout
@inject HttpClient Http
@using PortfolioFrontend.Models

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">Gelen Mesajlar</h3>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-accent" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!messages.Any())
    {
        <div class="alert alert-glass text-white text-center py-5">
            <i class="fas fa-envelope-open-text fa-2x mb-3 text-accent d-block"></i>
            Henüz hiç mesajınız yok.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover table-glass align-middle">
                <thead>
                    <tr>
                        <th scope="col">Gönderen</th>
                        <th scope="col">E-posta</th>
                        <th scope="col">Konu</th>
                        <th scope="col">Tarih</th>
                        <th scope="col" class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in messages)
                    {
                        <tr>
                            <td class="text-white fw-bold">@message.AdSoyad</td>
                            <td class="text-secondary small">
                                <a href="mailto:@message.Email" class="text-accent text-decoration-none">@message.Email</a>
                            </td>
                            <td class="text-white">@message.Konu</td>
                            <td class="text-secondary small">@message.GondermeTarihi.ToString("dd MMM yyyy HH:mm")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-info me-2" @onclick="() => ShowMessageDetail(message)">
                                    <i class="fas fa-eye"></i> Oku
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMessage(message.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (selectedMessage != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); overflow-y: auto;">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content glass-panel border-0">
                <div class="modal-header border-secondary border-opacity-25">
                    <h5 class="modal-title text-white">Mesaj Detayı</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body text-white">
                    <div class="mb-3">
                        <small class="text-accent">Gönderen:</small>
                        <div>@selectedMessage.AdSoyad</div>
                    </div>
                    <div class="mb-3">
                        <small class="text-accent">E-posta:</small>
                        <div><a href="mailto:@selectedMessage.Email" class="text-white">@selectedMessage.Email</a></div>
                    </div>
                    <div class="mb-3">
                        <small class="text-accent">Konu:</small>
                        <div class="fw-bold">@selectedMessage.Konu</div>
                    </div>
                    <div class="mb-3">
                        <small class="text-accent">Mesaj:</small>
                        <div class="p-3 mt-1 rounded bg-dark bg-opacity-50" style="white-space: pre-wrap;">@selectedMessage.Mesaj</div>
                    </div>
                    <div>
                        <small class="text-secondary">Tarih: @selectedMessage.GondermeTarihi.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">Kapat</button>
                    <button type="button" class="btn btn-outline-danger" @onclick="async () => { await DeleteMessage(selectedMessage.Id); CloseModal(); }">
                        <i class="fas fa-trash me-2"></i>Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .btn-accent {
        background-color: #64ffda;
        color: #0a192f;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    .table-glass {
        background: rgba(16, 33, 62, 0.5) !important;
        backdrop-filter: blur(10px);
        border-radius: 10px;
        overflow: hidden;
    }
    .table-glass th, .table-glass td {
        background-color: transparent !important;
        border-bottom-color: rgba(255,255,255,0.05);
    }
</style>

@code {
    private List<MessageDto> messages = new();
    private bool isLoading = true;
    private MessageDto? selectedMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<MessageDto>>("api/Messages");
            if (response != null)
            {
                messages = response.OrderByDescending(m => m.GondermeTarihi).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Mesajlar yüklenirken hata oluştu: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowMessageDetail(MessageDto message)
    {
        selectedMessage = message;
    }

    private void CloseModal()
    {
        selectedMessage = null;
    }

    private async Task DeleteMessage(int id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Messages/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadMessages();
            }
            else
            {
                Console.WriteLine("Mesaj silinemedi.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Mesaj silinirken hata: {ex.Message}");
        }
    }
}

