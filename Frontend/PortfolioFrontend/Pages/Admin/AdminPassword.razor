@page "/admin/password"
@layout AdminLayout
@inject HttpClient Http
@using PortfolioFrontend.Models
@using Microsoft.AspNetCore.Components.Forms

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">Şifre Değiştir</h3>
    </div>

    <div class="glass-panel p-4 p-md-5 mx-auto" style="max-width: 600px;">
        <EditForm Model="passwordModel" OnValidSubmit="ChangePassword">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert @(isSuccess ? "alert-success" : "alert-danger") border-0" style="background: @(isSuccess ? "rgba(40, 167, 69, 0.1)" : "rgba(220, 53, 69, 0.1)"); color: @(isSuccess ? "#28a745" : "#ff6b6b");">
                    @statusMessage
                </div>
            }

            <div class="mb-4">
                <label class="form-label text-white small">Mevcut Şifre</label>
                <div class="input-group">
                    <span class="input-group-text form-control-glass border-end-0">
                        <i class="fas fa-lock text-secondary"></i>
                    </span>
                    <InputText @bind-Value="passwordModel.CurrentPassword" type="@(showCurrentPassword ? "text" : "password")" class="form-control form-control-glass border-start-0 border-end-0 ps-3" placeholder="••••••••" />
                    <span class="input-group-text form-control-glass border-start-0" style="cursor: pointer;" @onclick="() => showCurrentPassword = !showCurrentPassword">
                        <i class="fas @(showCurrentPassword ? "fa-eye-slash" : "fa-eye") text-secondary"></i>
                    </span>
                </div>
                <ValidationMessage For="@(() => passwordModel.CurrentPassword)" class="text-danger small mt-1 d-block" />
            </div>

            <div class="mb-4">
                <label class="form-label text-white small">Yeni Şifre</label>
                <div class="input-group">
                    <span class="input-group-text form-control-glass border-end-0">
                        <i class="fas fa-key text-accent"></i>
                    </span>
                    <InputText @bind-Value="passwordModel.NewPassword" type="@(showNewPassword ? "text" : "password")" class="form-control form-control-glass border-start-0 border-end-0 ps-3" placeholder="••••••••" />
                    <span class="input-group-text form-control-glass border-start-0" style="cursor: pointer;" @onclick="() => showNewPassword = !showNewPassword">
                        <i class="fas @(showNewPassword ? "fa-eye-slash" : "fa-eye") text-secondary"></i>
                    </span>
                </div>
                <ValidationMessage For="@(() => passwordModel.NewPassword)" class="text-danger small mt-1 d-block" />
                <small class="text-secondary mt-2 d-block">Şifreniz en az 6 karakter olmalı ve en az bir büyük harf, küçük harf, rakam ve özel karakter içermelidir.</small>
            </div>

            <div class="mb-5">
                <label class="form-label text-white small">Yeni Şifre (Tekrar)</label>
                <div class="input-group">
                    <span class="input-group-text form-control-glass border-end-0">
                        <i class="fas fa-check-circle text-accent"></i>
                    </span>
                    <InputText @bind-Value="passwordModel.ConfirmPassword" type="@(showConfirmPassword ? "text" : "password")" class="form-control form-control-glass border-start-0 border-end-0 ps-3" placeholder="••••••••" />
                    <span class="input-group-text form-control-glass border-start-0" style="cursor: pointer;" @onclick="() => showConfirmPassword = !showConfirmPassword">
                        <i class="fas @(showConfirmPassword ? "fa-eye-slash" : "fa-eye") text-secondary"></i>
                    </span>
                </div>
                <ValidationMessage For="@(() => passwordModel.ConfirmPassword)" class="text-danger small mt-1 d-block" />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-accent py-2 fw-bold" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Değiştiriliyor...</span>
                    }
                    else
                    {
                        <i class="fas fa-save me-2"></i> <span>Şifreyi Güncelle</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private ChangePasswordDto passwordModel = new();
    private bool isSaving = false;
    private string statusMessage = "";
    private bool isSuccess = false;
    
    private bool showCurrentPassword = false;
    private bool showNewPassword = false;
    private bool showConfirmPassword = false;

    private async Task ChangePassword()
    {
        isSaving = true;
        statusMessage = "";
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/change-password", passwordModel);

            if (response.IsSuccessStatusCode)
            {
                isSuccess = true;
                statusMessage = "Şifreniz başarıyla değiştirildi.";
                passwordModel = new ChangePasswordDto(); // Formu temizle
            }
            else
            {
                isSuccess = false;
                statusMessage = "Mevcut şifrenizi yanlış girdiniz veya yeni şifreniz güvenlik kurallarını sağlamıyor.";
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            statusMessage = $"Bağlantı hatası: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
