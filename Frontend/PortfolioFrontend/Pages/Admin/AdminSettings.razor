@page "/admin/settings"
@layout AdminLayout
@inject HttpClient Http
@using PortfolioFrontend.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Headers

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">Site Ayarları</h3>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-accent" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <div class="glass-panel p-4 p-md-5">
            <EditForm Model="settings" OnValidSubmit="SaveSettings">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert @(isSuccess ? "alert-success" : "alert-danger")">
                        @statusMessage
                    </div>
                }

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label text-white small">Ad Soyad</label>
                        <InputText @bind-Value="settings.AdSoyad" class="form-control form-control-glass" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-white small">Ünvan</label>
                        <InputText @bind-Value="settings.Unvan" class="form-control form-control-glass" />
                    </div>
                    
                    <div class="col-12">
                        <label class="form-label text-white small">Hakkımda</label>
                        <InputTextArea @bind-Value="settings.Hakkimda" class="form-control form-control-glass" rows="5" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label text-white small">Profil Resmi Seç (İsteğe Bağlı)</label>
                        <InputFile OnChange="HandleProfilePhotoSelected" class="form-control form-control-glass" accept="image/*" />
                        @if (!string.IsNullOrEmpty(settings.ProfilFoto))
                        {
                            <div class="mt-2">
                                <span class="text-secondary small">Mevcut Profil Resmi:</span><br />
                                <img src="@(string.IsNullOrEmpty(settings.ProfilFoto) ? "" : (settings.ProfilFoto.StartsWith("http") ? settings.ProfilFoto : (settings.ProfilFoto.Contains("/") ? Http.BaseAddress + settings.ProfilFoto.TrimStart('/') : Http.BaseAddress + "images/" + settings.ProfilFoto)))" alt="Profil Foto" class="img-thumbnail bg-transparent border-secondary mt-1" style="height: 100px; object-fit: cover;" />
                            </div>
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label text-white small">CV Dosyası Seç (İsteğe Bağlı)</label>
                        <InputFile OnChange="HandleCvSelected" class="form-control form-control-glass" accept=".pdf,.doc,.docx" />
                        @if (!string.IsNullOrEmpty(settings.CvPath))
                        {
                            <div class="mt-2">
                                <span class="text-secondary small">Mevcut CV:</span><br />
                                <a href="https://localhost:7068/files/@settings.CvPath" target="_blank" class="text-accent mt-1 d-inline-block">
                                    <i class="fas fa-file-pdf me-1"></i> @settings.CvPath
                                </a>
                            </div>
                        }
                    </div>

                    <div class="col-12 text-end mt-5">
                        <button type="submit" class="btn btn-accent px-5 py-2 fw-bold" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Kaydediliyor...</span>
                            }
                            else
                            {
                                <i class="fas fa-save me-2"></i> <span>Ayarları Kaydet</span>
                            }
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    }
</div>

<style>
    .btn-accent {
        background-color: #64ffda;
        color: #0a192f;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    .btn-accent:hover {
        background-color: #52e0c4;
        transform: translateY(-2px);
        color: #0a192f;
    }
</style>

@code {
    private SiteSettingsDto settings = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string statusMessage = "";
    private bool isSuccess = false;

    private IBrowserFile? profilePhotoFile;
    private IBrowserFile? cvFile;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<SiteSettingsDto>>("api/SiteSettings");
            if (response != null && response.Any())
            {
                settings = response.First();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ayarlar yüklenirken hata oluştu: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleProfilePhotoSelected(InputFileChangeEventArgs e)
    {
        profilePhotoFile = e.File;
    }

    private void HandleCvSelected(InputFileChangeEventArgs e)
    {
        cvFile = e.File;
    }

    private async Task SaveSettings()
    {
        isSaving = true;
        statusMessage = "";
        
        try
        {
            using var content = new MultipartFormDataContent();
            content.Add(new StringContent(settings.Id.ToString()), "Id");
            content.Add(new StringContent(settings.AdSoyad ?? ""), "AdSoyad");
            content.Add(new StringContent(settings.Unvan ?? ""), "Unvan");
            content.Add(new StringContent(settings.Hakkimda ?? ""), "Hakkimda");
            

            content.Add(new StringContent("1"), "UserId");

            if (profilePhotoFile != null)
            {
                var fileContent = new StreamContent(profilePhotoFile.OpenReadStream(maxAllowedSize: 5120000));
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(profilePhotoFile.ContentType);
                content.Add(fileContent, "ProfilFotoFile", profilePhotoFile.Name);
            }
            
            if (cvFile != null)
            {
                var fileContent = new StreamContent(cvFile.OpenReadStream(maxAllowedSize: 10485760)); // 10MB limit
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(cvFile.ContentType);
                content.Add(fileContent, "CvFile", cvFile.Name);
            }

            HttpResponseMessage response;
            if (settings.Id == 0)
            {
                response = await Http.PostAsync("api/SiteSettings", content);
            }
            else
            {
                response = await Http.PutAsync("api/SiteSettings", content);
            }

            if (response.IsSuccessStatusCode)
            {
                isSuccess = true;
                statusMessage = "Ayarlar başarıyla güncellendi.";
                await LoadSettings(); // Yeniden yükle ki resim isimleri falan güncellensin
            }
            else
            {
                isSuccess = false;
                statusMessage = "Ayarlar güncellenirken bir hata oluştu.";
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            statusMessage = $"Hata: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
