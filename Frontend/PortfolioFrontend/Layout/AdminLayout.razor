@inherits LayoutComponentBase

<div class="admin-layout" style="min-height: 100vh; background-color: #0a192f; display: flex; font-family: 'Inter', sans-serif;">
    <AuthorizeView>
        <Authorized>
            <PageTitle>Eray Gülüçmen - Admin</PageTitle>

            <!-- Mobile Top Navbar -->
            <div class="d-md-none w-100 py-3 px-4 d-flex justify-content-between align-items-center" style="background-color: #020c1b; position: sticky; top: 0; z-index: 1010; border-bottom: 1px solid rgba(100, 255, 218, 0.2);">
                <h5 class="text-white mb-0 fw-bold"><i class="fas fa-user-shield text-accent me-2"></i>Admin</h5>
                <button class="btn text-accent border-0 p-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
                    <i class="fas fa-bars fs-2"></i>
                </button>
            </div>

            <!-- Mobile Offcanvas Sidebar -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel" style="background-color: #0a192f; width: 280px; border-right: 1px solid rgba(100, 255, 218, 0.2);">
                <div class="offcanvas-header border-bottom border-secondary border-opacity-25 py-3 d-flex justify-content-end">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body p-0">
                    <AdminSidebar />
                </div>
            </div>

            <!-- Desktop Sidebar -->
            <div class="d-none d-md-block h-100 position-fixed" style="width: 250px; z-index: 1000;">
                <AdminSidebar />
            </div>

            <!-- Content Area -->
            <div class="flex-grow-1 admin-content-wrapper">
                <div class="p-3 p-md-5 w-100">
                    @Body
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="w-100 d-flex align-items-center justify-content-center">
                @Body
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<style>
    .glass-panel {
        background: rgba(17, 34, 64, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(100, 255, 218, 0.1);
        border-radius: 15px;
    }
    
    .form-control-glass {
        background: rgba(2, 12, 27, 0.7) !important;
        border: 1px solid rgba(100, 255, 218, 0.2) !important;
        color: #ccd6f6 !important;
    }

    .form-control-glass::placeholder {
        color: rgba(204, 214, 246, 0.6) !important;
    }
    
    .form-control-glass:focus {
        box-shadow: 0 0 0 0.25rem rgba(100, 255, 218, 0.25) !important;
        border-color: #64ffda !important;
    }

    .btn-accent {
        background-color: transparent;
        color: #64ffda;
        border: 1px solid #64ffda;
        transition: all 0.3s ease;
    }

    .btn-accent:hover {
        background-color: rgba(100, 255, 218, 0.1);
        color: #64ffda;
        transform: translateY(-2px);
    }
    
    .table-responsive .table th, 
    .table-responsive .table td {
        white-space: nowrap;
        vertical-align: middle;
    }

    .admin-content-wrapper {
        margin-left: 250px;
    }

    @@media (max-width: 767.98px) {
        .admin-content-wrapper {
            margin-left: 0 !important;
        }
    }

    /* Sticky actions column for responsive tables */
    .table-responsive .table th:last-child,
    .table-responsive .table td:last-child {
        position: sticky;
        right: 0;
        background-color: #0d213f !important;
        z-index: 2;
        box-shadow: -5px 0 10px -5px rgba(0,0,0,0.5);
    }
</style>
